@startuml
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0

skinparam class {
  BackgroundColor<<Entity>> #FFF6D6
  BackgroundColor<<UseCase>> #FCE4EC
  BackgroundColor<<Interactor>> #FDECEC
  BackgroundColor<<Controller>> #E8F5E9
  BackgroundColor<<DTO>> #E3F2FD
  BackgroundColor<<GatewayPort>> #F3E5F5
  BackgroundColor<<GatewayAdapter>> #E1F5FE
  BackgroundColor<<Producer>> #ECEFF1
  BackgroundColor<<Bootstrap>> #ECEFF1
  BackgroundColor<<Utility>> #F5F5F5
  BorderColor #455A64
}

package "Framework & Drivers" {
  class RestApplication <<Bootstrap>> {
    +"@ApplicationPath('/api')"
  }

  class DataSourceProducer <<Producer>> {
    +dataSource(): DataSource
  }
}

package "Adapters In - REST" {
  class PlatController <<Controller>> {
    +getAll(): Response
    +getById(id: Long): Response
    +create(request: PlatRequest): Response
    +update(id: Long, request: PlatRequest): Response
    +delete(id: Long): Response
  }

  class UtilisateurController <<Controller>> {
    +getAll(): Response
    +getById(id: Long): Response
    +create(request: UtilisateurRequest): Response
    +update(id: Long, request: UtilisateurRequest): Response
    +delete(id: Long): Response
  }

  class HealthController <<Controller>> {
    +health(): Response
  }

  class CorsFilter <<Controller>> {
    +filter(requestContext: ContainerRequestContext): void
    +filter(requestContext: ContainerRequestContext, responseContext: ContainerResponseContext): void
  }

  class ApiResponses <<Utility>> {
    {static} +badRequest(message, uriInfo): Response
    {static} +notFound(message, uriInfo): Response
    {static} +conflict(message, uriInfo): Response
    {static} +internalServerError(uriInfo): Response
  }

  class PlatRequest <<DTO>>
  class PlatResponse <<DTO>>
  class UtilisateurRequest <<DTO>>
  class UtilisateurResponse <<DTO>>
  class HealthResponse <<DTO>>
  class ApiErrorResponse <<DTO>>
}

package "Application - Ports In" {
  interface ConsulterPlatsUseCase <<UseCase>> {
    +tousLesPlats(): List<Plat>
    +platParId(id: Long): Optional<Plat>
  }

  interface GererPlatsUseCase <<UseCase>> {
    +creer(nom, description, prix): Plat
    +modifier(id, nom, description, prix): Optional<Plat>
    +supprimer(id: Long): boolean
  }

  interface ConsulterUtilisateursUseCase <<UseCase>> {
    +tousLesUtilisateurs(): List<Utilisateur>
    +utilisateurParId(id: Long): Optional<Utilisateur>
  }

  interface GererUtilisateursUseCase <<UseCase>> {
    +creer(nom, prenom, email, adresse): Utilisateur
    +modifier(id, nom, prenom, email, adresse): Optional<Utilisateur>
    +supprimer(id: Long): boolean
  }
}

package "Application - Use Cases" {
  class ConsulterPlatsInteractor <<Interactor>> {
    +tousLesPlats(): List<Plat>
    +platParId(id: Long): Optional<Plat>
  }

  class GererPlatsInteractor <<Interactor>> {
    +creer(nom, description, prix): Plat
    +modifier(id, nom, description, prix): Optional<Plat>
    +supprimer(id: Long): boolean
  }

  class ConsulterUtilisateursInteractor <<Interactor>> {
    +tousLesUtilisateurs(): List<Utilisateur>
    +utilisateurParId(id: Long): Optional<Utilisateur>
  }

  class GererUtilisateursInteractor <<Interactor>> {
    +creer(nom, prenom, email, adresse): Utilisateur
    +modifier(id, nom, prenom, email, adresse): Optional<Utilisateur>
    +supprimer(id: Long): boolean
  }
}

package "Application - Ports Out" {
  interface PlatGateway <<GatewayPort>> {
    +findAll(): List<Plat>
    +findById(id: Long): Optional<Plat>
    +save(plat: Plat): Plat
    +update(id: Long, plat: Plat): Optional<Plat>
    +deleteById(id: Long): boolean
  }

  interface UtilisateurGateway <<GatewayPort>> {
    +findAll(): List<Utilisateur>
    +findById(id: Long): Optional<Utilisateur>
    +save(utilisateur: Utilisateur): Utilisateur
    +update(id: Long, utilisateur: Utilisateur): Optional<Utilisateur>
    +deleteById(id: Long): boolean
  }
}

package "Adapters Out - MySQL" {
  class MySqlPlatGateway <<GatewayAdapter>> {
    +findAll(): List<Plat>
    +findById(id: Long): Optional<Plat>
    +save(plat: Plat): Plat
    +update(id: Long, plat: Plat): Optional<Plat>
    +deleteById(id: Long): boolean
  }

  class MySqlUtilisateurGateway <<GatewayAdapter>> {
    +findAll(): List<Utilisateur>
    +findById(id: Long): Optional<Utilisateur>
    +save(utilisateur: Utilisateur): Utilisateur
    +update(id: Long, utilisateur: Utilisateur): Optional<Utilisateur>
    +deleteById(id: Long): boolean
  }
}

package "Domain" {
  class Plat <<Entity>> {
    -id: Long
    -nom: String
    -description: String
    -prix: BigDecimal
  }

  class Utilisateur <<Entity>> {
    -id: Long
    -nom: String
    -prenom: String
    -email: String
    -adresse: String
  }

  class DuplicateEmailException <<Entity>> {
    +DuplicateEmailException(message: String)
  }
}

class RuntimeException

ConsulterPlatsInteractor ..|> ConsulterPlatsUseCase
GererPlatsInteractor ..|> GererPlatsUseCase
ConsulterUtilisateursInteractor ..|> ConsulterUtilisateursUseCase
GererUtilisateursInteractor ..|> GererUtilisateursUseCase

MySqlPlatGateway ..|> PlatGateway
MySqlUtilisateurGateway ..|> UtilisateurGateway

PlatController ..> ConsulterPlatsUseCase
PlatController ..> GererPlatsUseCase
UtilisateurController ..> ConsulterUtilisateursUseCase
UtilisateurController ..> GererUtilisateursUseCase

ConsulterPlatsInteractor ..> PlatGateway : depends on
GererPlatsInteractor ..> PlatGateway : depends on
ConsulterUtilisateursInteractor ..> UtilisateurGateway : depends on
GererUtilisateursInteractor ..> UtilisateurGateway : depends on

ConsulterPlatsUseCase ..> Plat
GererPlatsUseCase ..> Plat
ConsulterUtilisateursUseCase ..> Utilisateur
GererUtilisateursUseCase ..> Utilisateur

PlatGateway ..> Plat
UtilisateurGateway ..> Utilisateur

MySqlPlatGateway ..> DataSourceProducer : uses DataSource
MySqlUtilisateurGateway ..> DataSourceProducer : uses DataSource
MySqlUtilisateurGateway ..> DuplicateEmailException : throws on unique email
DuplicateEmailException --|> RuntimeException

PlatController ..> PlatRequest
PlatController ..> PlatResponse
UtilisateurController ..> UtilisateurRequest
UtilisateurController ..> UtilisateurResponse
HealthController ..> HealthResponse
PlatController ..> ApiResponses
UtilisateurController ..> ApiResponses
ApiResponses ..> ApiErrorResponse

RestApplication ..> PlatController
RestApplication ..> UtilisateurController
RestApplication ..> HealthController
RestApplication ..> CorsFilter

note right of GererPlatsInteractor
Regles metier Plats:
- id > 0 pour update/delete
- nom obligatoire, max 150
- description optionnelle, max 500
- prix > 0 et max 2 decimales
end note

note right of GererUtilisateursInteractor
Regles metier Utilisateurs:
- id > 0 pour update/delete
- nom obligatoire, max 120
- prenom obligatoire, max 120
- email valide, normalise, unique, max 255
- adresse optionnelle, max 255
end note

legend right
  <<Bootstrap>> point d'entree JAX-RS
  <<Controller>> adapter entrant REST
  <<UseCase>> port d'entree application
  <<Interactor>> implementation de cas d'usage
  <<GatewayPort>> port de sortie application
  <<GatewayAdapter>> adapter sortant MySQL
  <<Entity>> coeur de domaine
  <<DTO>> objet de transport API
  <<Utility>> helper statique API
endlegend

note bottom
  Regle Clean Architecture:
  les dependances pointent vers l'interieur
  (adapters/framework -> application -> domain)
end note

@enduml
